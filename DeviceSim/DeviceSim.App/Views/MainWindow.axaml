<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DeviceSim.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="using:DeviceSim.App.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="DeviceSim.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="GridGhost"
        Icon="avares://GridGhost/Assets/Icons/gridghost_icon.ico">

    <Window.Resources>
        <conv:SidebarWidthConverter x:Key="SidebarWidthConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="StackPanel#HeaderPanel">
            <Setter Property="Margin" Value="15,15,10,25"/>
        </Style>
        <Style Selector="StackPanel#HeaderPanel.collapsed">
            <Setter Property="Margin" Value="10,15,10,25"/>
        </Style>
        <Style Selector="StackPanel#HeaderPanel Button">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="StackPanel#HeaderPanel.collapsed Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="44"/>
        </Style>
        
        <!-- Hamburger Path Rotation -->
        <Style Selector="StackPanel#HeaderPanel Button Path">
            <Setter Property="RenderTransform" Value="rotate(180deg)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="StackPanel#HeaderPanel.collapsed Button Path">
            <Setter Property="RenderTransform" Value="rotate(0deg)"/>
        </Style>

        <!-- Header Logo Panel Transition -->
        <Style Selector="StackPanel#HeaderLogoPanel">
            <Setter Property="MaxWidth" Value="200"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxWidth" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                    <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="StackPanel#HeaderPanel.collapsed StackPanel#HeaderLogoPanel">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style Selector="StackPanel#NavPanel.collapsed">
            <Setter Property="Margin" Value="10,0,10,0"/>
        </Style>
        <Style Selector="Button.SidebarItem.collapsed">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Sidebar Items Spacing & Text Transitions -->
        <Style Selector="Button.SidebarItem StackPanel">
            <Setter Property="Spacing" Value="15"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Spacing" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SidebarItem.collapsed StackPanel">
            <Setter Property="Spacing" Value="0"/>
        </Style>
        <Style Selector="Button.SidebarItem TextBlock">
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxWidth" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SidebarItem.collapsed TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Donate Button Transitions -->
        <Style Selector="Button#DonateBtn">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
        <Style Selector="Button#DonateBtn.collapsed">
            <Setter Property="Margin" Value="10,0,10,16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button#DonateBtn StackPanel">
            <Setter Property="Spacing" Value="15"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Spacing" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#DonateBtn.collapsed StackPanel">
            <Setter Property="Spacing" Value="0"/>
        </Style>
        <Style Selector="Button#DonateBtn TextBlock">
            <Setter Property="MaxWidth" Value="150"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="MaxWidth" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#DonateBtn.collapsed TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Button.SidebarActive Path">
            <Setter Property="Fill" Value="{StaticResource AccentMain}"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Width="{Binding IsSidebarCollapsed, Converter={StaticResource SidebarWidthConverter}}"
                Background="{StaticResource SidebarBackground}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="0,0,1,0"
                ClipToBounds="True">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <Grid RowDefinitions="Auto, Auto, *, Auto">
                <!-- Header with Hamburger -->
                <StackPanel Name="HeaderPanel" Grid.Row="0" Classes.collapsed="{Binding IsSidebarCollapsed}" Orientation="Horizontal">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Background="Transparent" CornerRadius="8">
                        <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" 
                              Fill="{StaticResource TextPrimary}"
                              Stretch="Uniform" Width="20" Height="20"
                              RenderTransformOrigin="50%,50%"/>
                    </Button>
                    
                    <StackPanel Name="HeaderLogoPanel" Orientation="Horizontal" Spacing="10">
                        <Viewbox Width="28" Height="28" VerticalAlignment="Center">
                            <Canvas Width="512" Height="512">
                                <!-- Ghost Body and Eyes -->
                                <Path Data="M508.374,432.802c0,0-46.6-39.038-79.495-275.781C420.046,69.341,346.023,0.882,256,0.882 c-90.015,0-164.046,68.458-172.879,156.138C50.226,393.763,3.626,432.802,3.626,432.802c-15.107,25.181,20.733,28.178,38.699,27.94 c35.254-0.478,35.254,40.294,70.516,40.294c35.254,0,35.254-35.261,70.508-35.261s37.396,45.343,72.65,45.343 s37.389-45.343,72.651-45.343c35.254,0,35.254,35.261,70.508,35.261s35.27-40.772,70.524-40.294 C487.641,460.98,523.48,457.982,508.374,432.802z M208.769,225.031c-12.518,0-22.676-10.15-22.676-22.675 c0-12.518,10.158-22.66,22.676-22.66c12.516,0,22.66,10.142,22.66,22.66C231.429,214.881,221.285,225.031,208.769,225.031z M297.983,225.031c-12.525,0-22.668-10.15-22.668-22.675c0-12.518,10.143-22.66,22.668-22.66c12.509,0,22.667,10.142,22.667,22.66 C320.65,214.881,310.492,225.031,297.983,225.031z"
                                      Fill="{StaticResource AccentMain}"/>
                                <!-- Central grid holes for the mouth -->
                                <Rectangle Canvas.Left="206" Canvas.Top="250" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="226" Canvas.Top="250" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="246" Canvas.Top="250" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="266" Canvas.Top="250" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="286" Canvas.Top="250" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                
                                <Rectangle Canvas.Left="206" Canvas.Top="270" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="226" Canvas.Top="270" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="246" Canvas.Top="270" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="266" Canvas.Top="270" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="286" Canvas.Top="270" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                
                                <Rectangle Canvas.Left="206" Canvas.Top="290" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="226" Canvas.Top="290" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="246" Canvas.Top="290" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="266" Canvas.Top="290" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                                <Rectangle Canvas.Left="286" Canvas.Top="290" Width="14" Height="14" Fill="{StaticResource SidebarBackground}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="GridGhost" Foreground="{StaticResource AccentMain}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Name="NavPanel" Grid.Row="1" Spacing="8" Margin="15,0,10,0" Classes.collapsed="{Binding IsSidebarCollapsed}">
                    <Button Classes="SidebarItem" Classes.collapsed="{Binding IsSidebarCollapsed}" Classes.SidebarActive="{Binding IsDevicesActive}" Command="{Binding NavigateCommand}" CommandParameter="Devices" 
                            ToolTip.Tip="Devices">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M4,7V19H20V7H4M11,10H13V12H11V10M8,10H10V12H8V10M11,13H13V15H11V13M8,13H10V15H8V13M4,13H6V15H4V13M4,10H6V12H4V10M14,10H16V12H14V10M17,10H19V12H17V10M14,13H16V15H14V13M17,13H19V15H17V13Z" 
                                  Fill="{StaticResource TextSecondary}" Stretch="Uniform" Width="20" Height="20"/>
                            <TextBlock Text="Devices" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="SidebarItem" Classes.collapsed="{Binding IsSidebarCollapsed}" Classes.SidebarActive="{Binding IsPointsActive}" Command="{Binding NavigateCommand}" CommandParameter="Points"
                            ToolTip.Tip="Points Monitor">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M19.14,12.94C19.14,12.63 19.17,12.32 19.17,12C19.17,11.68 19.14,11.37 19.14,11.06L20.52,9.98C20.64,9.88 20.68,9.71 20.59,9.58L19.29,7.33C19.2,7.21 19.04,7.16 18.91,7.21L17.28,7.87C16.94,7.61 16.57,7.39 16.17,7.23L15.92,5.5C15.89,5.36 15.77,5.25 15.63,5.25H13.04C12.9,5.25 12.78,5.36 12.75,5.5L12.5,7.23C12.1,7.39 11.73,7.61 11.39,7.87L9.76,7.21C9.63,7.16 9.47,7.21 9.38,7.33L8.08,9.58C7.99,9.71 8.03,9.88 8.15,9.98L9.53,11.06C9.53,11.37 9.5,11.68 9.5,12C9.5,12.32 9.53,12.63 9.53,12.94L8.15,14.02C8.03,14.12 7.99,14.29 8.08,14.42L9.38,16.67C9.47,16.79 9.63,16.84 9.76,16.79L11.39,16.13C11.73,16.39 12.1,16.61 12.5,16.77L12.75,18.5C12.78,18.64 12.9,18.75 13.04,18.75H15.63C15.77,18.75 15.89,18.64 15.92,18.5L16.17,16.77C16.57,16.61 16.94,16.39 17.28,16.13L18.91,16.79C19.04,16.84 19.2,16.79 19.29,16.67L20.59,14.42C20.68,14.29 20.64,14.12 20.52,14.02L19.14,12.94M14.33,14.75C12.81,14.75 11.58,13.52 11.58,12C11.58,10.48 12.81,9.25 14.33,9.25C15.85,9.25 17.08,10.48 17.08,12C17.08,13.52 15.85,14.75 14.33,14.75Z" 
                                  Fill="{StaticResource TextSecondary}" Stretch="Uniform" Width="20" Height="20"/>
                            <TextBlock Text="Points Monitor" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
 
                    <Button Classes="SidebarItem" Classes.collapsed="{Binding IsSidebarCollapsed}" Classes.SidebarActive="{Binding IsTemplatesActive}" Command="{Binding NavigateCommand}" CommandParameter="Templates"
                            ToolTip.Tip="Device Builder">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20C4,21.1 4.89,22 6,22H18C19.1,22 20,21.1 20,20V8L14,2H6Z" 
                                  Fill="{StaticResource TextSecondary}" Stretch="Uniform" Width="20" Height="20"/>
                            <TextBlock Text="Device Builder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="SidebarItem" Classes.collapsed="{Binding IsSidebarCollapsed}" Classes.SidebarActive="{Binding IsLogsActive}" Command="{Binding NavigateCommand}" CommandParameter="Logs"
                            ToolTip.Tip="Logs">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M14,17H7V15H14V17M17,13H7V11H17V13M17,9H7V7H17V9M19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3Z" 
                                  Fill="{StaticResource TextSecondary}" Stretch="Uniform" Width="20" Height="20"/>
                            <TextBlock Text="Logs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Button Grid.Row="3" Name="DonateBtn" Command="{Binding OpenDonationCommand}" 
                        Classes.collapsed="{Binding IsSidebarCollapsed}"
                        HorizontalAlignment="Stretch"
                        Background="#FFDD00" Foreground="Black" Height="45"
                        CornerRadius="8" Margin="15,0,15,16">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M2,21H20V19H2V21M20,8H18V5H20V8M20,3H4V13A4,4 0 0,0 8,17H14A4,4 0 0,0 18,13V10H20A2,2 0 0,0 22,8V5A2,2 0 0,0 20,3M16,13A2,2 0 0,1 14,15H8A2,2 0 0,1 6,13V5H16V13Z" 
                              Fill="Black" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Buy me a coffee" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Panel Grid.Column="1" Background="{StaticResource AppBackground}">
            <!-- Faint Radial Gradient Decoration -->
            <Ellipse Fill="#1544ff44" Width="800" Height="800" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-400,-400">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>

            <TransitioningContentControl Content="{Binding CurrentView}" Margin="20">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.2"/>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Panel>

        <!-- Intercept Dialog Overlay for Unsaved Changes -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#cc000000" IsVisible="{Binding IsConfirmNavigateVisible}" ZIndex="100">
            <Border Background="{StaticResource PanelBackground}" Width="400" MaxHeight="250" CornerRadius="14" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <StackPanel VerticalAlignment="Center" Spacing="25">
                    <TextBlock Text="Unsaved Changes" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="You have unsaved changes in the current view. How would you like to proceed?" 
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Button Content="Save" Command="{Binding ConfirmNavigateSaveCommand}" Classes="Accent" Width="100" HorizontalContentAlignment="Center"/>
                        <Button Content="Discard" Command="{Binding ConfirmNavigateDiscardCommand}" Classes="Danger" Width="100" HorizontalContentAlignment="Center"/>
                        <Button Content="Cancel" Command="{Binding ConfirmNavigateCancelCommand}" Width="100" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Enable Gate Overlay: shown when enabling a device with unsaved config -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#cc000000" IsVisible="{Binding IsEnableGateVisible}" ZIndex="150">
            <Border Background="{StaticResource PanelBackground}" Width="420" MaxHeight="260" CornerRadius="14"
                    BorderBrush="{StaticResource AccentColor}" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <StackPanel VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="Unsaved Changes" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" TextAlignment="Center">
                        <Run Text="Save changes before enabling "/>
                        <Run Text="{Binding EnableGateDeviceName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <Run Text="?"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Button Content="Save &amp; Enable" Command="{Binding EnableGateSaveAndStartCommand}" Classes="Accent" Width="120" HorizontalContentAlignment="Center"/>
                        <Button Content="Discard &amp; Enable" Command="{Binding EnableGateDiscardAndStartCommand}" Classes="Danger" Width="130" HorizontalContentAlignment="Center"/>
                        <Button Content="Cancel" Command="{Binding EnableGateCancelCommand}" Width="80" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Error Dialog Overlay -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#cc000000" IsVisible="{Binding IsErrorDialogVisible}" ZIndex="200">
            <Border Background="{StaticResource PanelBackground}" Width="450" MinHeight="180" CornerRadius="14" 
                    BorderBrush="{StaticResource DangerMain}" BorderThickness="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <StackPanel VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="{Binding ErrorDialogTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DangerMain}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorDialogMessage}" 
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" TextAlignment="Center"/>
                    <Button Content="Dismiss" Command="{Binding CloseErrorDialogCommand}" Width="100" HorizontalContentAlignment="Center" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>

</Window>
